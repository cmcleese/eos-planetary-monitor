{
  "name": "eos-planetary-monitor",
  "version": "0.1.0",
  "description": "A geospatial data interface.",
  "private": true,
  "scripts": {
    "dev:vue": "pnpm --filter vue-epm dev",
    "dev:react": "pnpm --filter react-epm dev",
    "build:all": "pnpm --filter \"*\" build",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check:all": "pnpm --filter \"*\" run type-check",
    "clean:all": "rimraf **/node_modules **/pnpm-lock.yaml && pnpm install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "cmcleese",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "globals": "^17.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.2"
  }
}
