{
  "name": "vue-epm",
  "description": "Vue 3 implementation of the EOS Planetary Monitor.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "clean": "rimraf node_modules pnpm-lock.yaml && pnpm install",
    "cache-clear": "rimraf .vite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@lucide/vue": "^1.7.0",
    "@vueuse/core": "^12.4.0",
    "cesium": "^1.125.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.0.0",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint-plugin-vue": "^9.32.0",
    "sass-embedded": "^1.83.4",
    "tailwindcss": "^4.0.0",
    "vite-plugin-cesium": "^1.2.23",
    "vue-tsc": "^2.2.0"
  }
}
