{
  "name": "vue-epm",
  "description": "Vue 3 implementation of the EOS Planetary Monitor.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf node_modules pnpm-lock.yaml && pnpm install",
    "cache-clear": "rimraf .vite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "cesium": "^1.137.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
